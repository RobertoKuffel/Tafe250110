<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Calculator.BlankPage1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Calculator"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Grid>
		
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Margin="30,10,30,0" Grid.RowSpan="3">
			<!-- Title -->
			<TextBlock Text="Currency Conversion Calculator" 
                       FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

			<!-- Input Headers -->
			<Grid Margin="0,0,0,5">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<TextBlock Grid.Column="0" Text="Amount $" 
                         FontSize="40" HorizontalAlignment="Left" FontWeight="Bold"/>
				<TextBlock Grid.Column="1" Text="From" 
                         FontSize="40" HorizontalAlignment="Left" FontWeight="Bold"/>
				<TextBlock Grid.Column="2" Text="To" 
                         FontSize="40" HorizontalAlignment="Left" FontWeight="Bold"/>
			</Grid>

			<!-- Input Controls -->
			<Grid Margin="0,0,0,10">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="407*"/>
					<ColumnDefinition Width="16*"/>
					<ColumnDefinition Width="11*"/>
					<ColumnDefinition Width="35*"/>
					<ColumnDefinition Width="345*"/>
					<ColumnDefinition Width="406*"/>
				</Grid.ColumnDefinitions>
				<Frame x:Name="MainFrame" />
				<TextBox x:Name="AmountTextBox" Grid.Column="0" Margin="0,0,203,0" Text="1000" FontSize="20"/>
				<ComboBox x:Name="FromCurrencyComboBox" Grid.Column="1" 
                        Height="41" 
                        SelectedIndex="0" Grid.ColumnSpan="4" VerticalAlignment="Center" Width="217" FontSize="20">
					<ComboBoxItem>USD - US Dollar</ComboBoxItem>
					<ComboBoxItem>EUR - Euro</ComboBoxItem>
					<ComboBoxItem>GBP - British Pound</ComboBoxItem>
					<ComboBoxItem>INR - Indian Rupee</ComboBoxItem>
				</ComboBox>
				<ComboBox x:Name="ToCurrencyComboBox" Grid.Column="5" 
                        Height="41" 
                        SelectedIndex="2" VerticalAlignment="Center" Width="203" FontSize="20">
					<ComboBoxItem>USD - US Dollar</ComboBoxItem>
					<ComboBoxItem>EUR - Euro</ComboBoxItem>
					<ComboBoxItem>GBP - British Pound</ComboBoxItem>
					<ComboBoxItem>INR - Indian Rupee</ComboBoxItem>
				</ComboBox>
			</Grid>

			<!-- Result Labels -->
			<TextBlock x:Name="DollarResultLabel" 
                     Text="1000 US Dollars ="
                     Margin="0,5,0,0" HorizontalAlignment="Left" FontSize="18" FontWeight="Bold"/>
			<TextBlock x:Name="ResultLabel" 
                     Text="$728.72436000 British Pounds"
                     FontWeight="Bold"
                     FontSize="20"/>

			<TextBlock x:Name="DollarToPoundsLabel" 
                     Text="1 USD = 0.72872436 British Pounds"
                     Margin="0,5,0,0" HorizontalAlignment="Left" FontSize="20" FontWeight="Bold"/>

			<TextBlock x:Name="PoundsToDollarLabel" 
                     Text="1 British Pound = 1.37190 USD"
                     Margin="0,5,0,20" HorizontalAlignment="Left" FontSize="20" FontWeight="Bold"/>

			<!-- Buttons centered as in the image -->
			<StackPanel HorizontalAlignment="Center" Orientation="Vertical">
				<Button x:Name="ConvertButton" 
                      Content="Currency conversion"
                      Width="230" Height="50" 
                      Background="LightGray"
                      Margin="0,0,0,10" FontSize="20" FontWeight="Bold" Click="ConvertButton_Click"/>

				<Button x:Name="ExitButton" 
                      Content="Exit"
                      Width="231" Height="45" 
                      Background="LightGray" FontSize="20" FontWeight="Bold" Click="ExitButton_Click_1"/>
			</StackPanel>
		</StackPanel>
	</Grid>
</Page>

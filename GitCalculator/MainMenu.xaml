<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Calculator.MainMenu"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Calculator"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Grid Background="#FF717171">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header section -->
            <RowDefinition Height="*"/>
            <!-- Content section -->
        </Grid.RowDefinitions>

        <!-- Header with title and logo -->
        <Grid Grid.Row="0" Margin="0,10,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Title column -->
                <ColumnDefinition Width="Auto"/>
                <!-- Logo column -->
            </Grid.ColumnDefinitions>
				
            <!-- Calculator Title -->
            <TextBlock Grid.Column="0"
                       Text="Universal Calculator"
                       FontSize="28" FontWeight="Bold"
                       VerticalAlignment="Center" HorizontalAlignment="Center" Margin="100,0,0,0"/>

            <!-- Logo Image -->
            <Image Grid.Column="1"
                   Source="Assets/abacus.png"
                   Width="100" Height="100"
                   Margin="0,0,20,0"/>
        </Grid>
		<!-- Content area with buttons -->
		<StackPanel Grid.Row="1"
            Orientation="Vertical"
            Margin="20">
			<Frame x:Name="MainFrame" />

			<!-- Calculator Buttons -->
			<Button Content="Math Calculator" 
            Width="400" Height="50" 
            Margin="0,0,0,10"
            FontSize="14"
            Background="#FFD6C3A6"
            BorderBrush="#FFD6C3A6"
            Foreground="Black"
            x:Name="btnMathCalculator" HorizontalAlignment="Center" Click="MathCalculatorButton_Click"/>

			<Button Content="Mortgage Calculator" 
            Width="400" Height="50" 
            Margin="0,0,0,10"
            FontSize="14"
            Background="#FFD6C3A6"
            BorderBrush="#FFD6C3A6"
            Foreground="Black"
            x:Name="btnMortgageCalculator" HorizontalAlignment="Center" Click="MortgageCalculatorButton_Click"/>

			<Button Content="Currency Converter" 
            Width="400" Height="50" 
            Margin="0,0,0,10"
            FontSize="14"
            Background="#FFD6C3A6"
            BorderBrush="#FFD6C3A6"
            Foreground="Black"
            x:Name="btnCurrencyConverter" HorizontalAlignment="Center" Click="CurrencyConverterButton_Click"/>

			<Button Content="Exit" 
            Width="400" Height="50" 
            FontSize="14"
            Background="#FFD6C3A6"
            BorderBrush="#FFD6C3A6"
            Foreground="Black"
            x:Name="btnExit" HorizontalAlignment="Center" Click="ExitButton_Click"/>

			<!-- NEW: Trip Calculator Button -->
			<Button Content="Trip Calculator" 
            Width="400" Height="50" 
            Margin="0,10,0,0"
            FontSize="14"
            Background="#FFD6C3A6"
            BorderBrush="#FFD6C3A6"
            Foreground="Black"
            x:Name="btnTripCalculator" HorizontalAlignment="Center" Click="TripCalculatorButton_Click"/>

			<TextBlock x:Name="txtTripError"
           Text=""
           FontSize="14"
           Foreground="Red"
           Margin="0,10,0,0"
           HorizontalAlignment="Center"
           TextWrapping="Wrap"
           Visibility="Collapsed"/>
		</StackPanel>

	</Grid>
</Page>
